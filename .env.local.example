# Frontend environment example
# Copy to .env.local for local development.

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_USE_ADMIN_API=true

# Optional explicit overrides. By default the app derives these from VITE_API_BASE_URL.
VITE_ADMIN_API_BASE_URL=
VITE_PARTNER_API_BASE_URL=

# Optional SSE endpoint. Leave empty in local mock mode.
VITE_PARTNER_EVENTS_URL=

# Deployed API through CloudFront + ECS:
# VITE_API_BASE_URL=https://d3t1pbvtir1lj.cloudfront.net
