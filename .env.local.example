# Frontend environment example
# Copy to .env.local for local development.

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_USE_ADMIN_API=true

# Optional explicit overrides. By default the app derives these from VITE_API_BASE_URL.
VITE_ADMIN_API_BASE_URL=
VITE_PARTNER_API_BASE_URL=
# Optional consulting realtime/API root override. If empty, realtime derives from
# VITE_PARTNER_API_BASE_URL first, then VITE_API_BASE_URL.
VITE_CONSULTING_API_BASE_URL=

# For 302 mobile + partner web local E2E, point these at the same 302 backend
# that the mobile app uses. That backend must listen on 0.0.0.0 for real devices:
# VITE_PARTNER_API_BASE_URL=http://<mac-lan-ip>:8000/api/consulting/partner
# VITE_CONSULTING_API_BASE_URL=http://<mac-lan-ip>:8000/api/consulting

# Optional SSE endpoint. Leave empty in local mock mode.
VITE_PARTNER_EVENTS_URL=

# Deployed API through CloudFront + ECS:
# VITE_API_BASE_URL=https://d3t1pbvtir1lj.cloudfront.net
