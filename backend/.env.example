# Backend environment example
# Copy to .env and fill real values locally or in the deployment secret manager.

ENVIRONMENT=local

# Database: shared AWS RDS Postgres
# ECS/production should prefer DATABASE_SECRET_ID.
DATABASE_SECRET_ID=
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=aura_prod
DB_SSLMODE=require

# Local fallback only, if you are not using DATABASE_SECRET_ID.
DATABASE_URL=
DB_USER=
DB_PASSWORD=

# AWS
AWS_REGION=ap-northeast-2
AWS_USE_IAM_ROLE=true

# Local fallback only. ECS should use IAM Role, not access keys.
AWS_PROFILE_NAME=

# S3: shared bucket with separated prefixes
S3_BUCKET_NAME=aura-mobile-media-dev

# Amazon Chime SDK Meetings. These must be enabled in the API environment
# before the partner workspace can create/join video meetings.
CHIME_ENABLED=false
CHIME_REGION=ap-northeast-2
CHIME_MEDIA_REGION=ap-northeast-2
CONSULTING_CALL_JOIN_EARLY_MINUTES=15
CONSULTING_CALL_JOIN_LATE_MINUTES=30
CONSULTING_CALL_TRANSCRIPTION_ENABLED=false
CONSULTING_CALL_TRANSLATION_ENABLED=false

# App integration
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,https://consultant-web-rose.vercel.app
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Amazon SES partner application emails
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=AURA 파트너팀
EMAIL_REPLY_TO_ADDRESS=
EMAIL_VERIFICATION_SECRET=

# OpenAI summary generation
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=
